<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.forme.jobhub.source-scan</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>__FORME_ROOT__/scripts/scan-sources.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartCalendarInterval</key>
    <array>
      <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>30</integer>
      </dict>
      <dict>
        <key>Hour</key>
        <integer>18</integer>
        <key>Minute</key>
        <integer>30</integer>
      </dict>
    </array>
    <key>WorkingDirectory</key>
    <string>__FORME_ROOT__</string>
    <key>StandardOutPath</key>
    <string>__FORME_ROOT__/data/logs/source-scan.launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__FORME_ROOT__/data/logs/source-scan.launchd.err.log</string>
  </dict>
</plist>
