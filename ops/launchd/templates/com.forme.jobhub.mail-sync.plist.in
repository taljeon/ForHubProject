<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.forme.jobhub.mail-sync</string>
    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>__FORME_ROOT__/scripts/sync-mail.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>1800</integer>
    <key>WorkingDirectory</key>
    <string>__FORME_ROOT__</string>
    <key>StandardOutPath</key>
    <string>__FORME_ROOT__/data/logs/mail-sync.launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__FORME_ROOT__/data/logs/mail-sync.launchd.err.log</string>
  </dict>
</plist>
