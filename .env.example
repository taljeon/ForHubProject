FORME_APP_NAME="Forme 就活ハブ"
FORME_TIMEZONE="Asia/Tokyo"

# ルート / データディレクトリ上書き
# FORME_ROOT_DIR="/path/to/forme-local"
# FORME_DATA_DIR="/path/to/forme-local/data"

# SQLite / blob storage
# FORME_DB_PATH="/path/to/forme-local/data/forme.db"
# FORME_BLOB_DIR="/path/to/forme-local/data/blobs"
# FORME_BLOB_BACKEND="local"
# FORME_DRIVE_BLOB_FOLDER_ID=""

# ソースレジストリ / Playwright 認証
# FORME_SOURCE_REGISTRY="/path/to/forme-local/config/source_registry.json"
# FORME_PLAYWRIGHT_AUTH_DIR="/path/to/forme-local/playwright/.auth"

# ダッシュボード / ログ
# FORME_DASHBOARD_HOST="127.0.0.1"
# FORME_DASHBOARD_PORT="8000"
# FORME_LOG_DIR="/path/to/forme-local/data/logs"
# FORME_ALLOWED_HOSTS="127.0.0.1,localhost,testserver"
FORME_REQUIRE_LOCALHOST="1"
FORME_REQUIRE_SAME_ORIGIN_POSTS="1"
FORME_ENABLE_DEMO_TOOLS="0"
FORME_ENABLE_API_DOCS="0"

# Gmail OAuth
# FORME_GMAIL_CREDENTIALS="/path/to/forme-local/auth/google-oauth/credentials.json"
# FORME_GMAIL_TOKEN="/path/to/forme-local/auth/google-oauth/token.json"
# FORME_GMAIL_DIGEST_RECIPIENT="your.name@example.com"
FORME_GMAIL_DIGEST_SUBJECT_PREFIX="[Forme]"
# FORME_GOOGLE_CALENDAR_ID="primary"
FORME_AUTO_CREATE_CALENDAR_EVENTS_FROM_MAIL="0"
FORME_LOCAL_LLM_MAIL_SCHEDULE_MIN_CONFIDENCE="0.8"
FORME_MAIL_CALENDAR_DEFAULT_DURATION_MINUTES="60"

# ローカル LLM
FORME_LOCAL_LLM_BACKEND="mlx"
FORME_LOCAL_LLM_MODEL="gemma4:e4b-it-8bit"
# MLX backend では上の Gemma alias を内部で解決します。
# Ollama に戻す場合は FORME_LOCAL_LLM_OLLAMA_HOST をそのまま使えます。
FORME_LOCAL_LLM_OLLAMA_HOST="http://127.0.0.1:11434"
FORME_LOCAL_LLM_TEMPERATURE="0.1"
FORME_LOCAL_LLM_MAX_TOKENS="900"
FORME_LOCAL_LLM_MAX_PROMPT_CHARS="18000"

# 重いローカル推論を避けたい場合は scan 時分類を OFF のままにします
FORME_AUTO_CLASSIFY_JOBS_WITH_LOCAL_LLM="0"
FORME_AUTO_REFINE_SCANNED_JOBS_WITH_LOCAL_LLM="1"
FORME_AUTO_REFINE_SCANNED_JOBS_LIMIT="8"
FORME_AUTO_CLASSIFY_MAIL_REVIEW_WITH_LOCAL_LLM="0"
FORME_LOCAL_LLM_MAIL_REVIEW_MIN_CONFIDENCE="0.85"
FORME_ALLOW_AUTOMATIC_MAIL_LOCAL_LLM="0"

# Digest 自動化
FORME_AUTO_DIGEST_WITH_LOCAL_LLM="0"
